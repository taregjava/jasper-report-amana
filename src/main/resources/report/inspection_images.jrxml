<?xml version="1.0" encoding="UTF-8"?>

<jasperReport
        xmlns="http://jasperreports.sourceforge.net/jasperreports"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"

        xsi:schemaLocation="
        http://jasperreports.sourceforge.net/jasperreports
        http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"

        name="inspection_images"

        pageWidth="250"
        pageHeight="300"

        columnWidth="250"

        leftMargin="0"
        rightMargin="0"
        topMargin="0"
        bottomMargin="0">


    <field name="imagePath" class="java.net.URL"/>


    <detail>

        <band height="150">

            <image>

                <reportElement
                        x="0"
                        y="0"
                        width="250"
                        height="150"/>

                <imageExpression class="java.net.URL"><![CDATA[
                $F{imagePath}
                ]]></imageExpression>

            </image>

        </band>

    </detail>

</jasperReport>