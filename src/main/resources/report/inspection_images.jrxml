<?xml version="1.0" encoding="UTF-8"?>

<jasperReport
        xmlns="http://jasperreports.sourceforge.net/jasperreports"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"

        xsi:schemaLocation="
        http://jasperreports.sourceforge.net/jasperreports
        http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"

        name="inspection_images"

        pageWidth="250"
        pageHeight="300"

        columnWidth="250"

        leftMargin="0"
        rightMargin="0"
        topMargin="0"
        bottomMargin="0">


    <field name="imagePath" class="java.net.URL"/>


    <detail>

        <band height="158">

            <!-- outer frame: light background + border -->
            <frame>
                <reportElement x="4" y="4" width="242" height="150" mode="Opaque" backcolor="#F8F8F8"/>
                <box>
                    <pen lineWidth="0.5" lineColor="#CCCCCC"/>
                </box>

                <!-- image centered inside frame with inner padding -->
                <image scaleImage="RetainShape" hAlign="Center" vAlign="Middle">
                    <reportElement x="4" y="4" width="234" height="142">
                        <printWhenExpression><![CDATA[$F{imagePath} != null]]></printWhenExpression>
                    </reportElement>
                    <imageExpression class="java.net.URL"><![CDATA[$F{imagePath}]]></imageExpression>
                </image>

                <!-- placeholder when no image -->
                <staticText>
                    <reportElement x="0" y="0" width="242" height="150" forecolor="#AAAAAA" mode="Transparent">
                        <printWhenExpression><![CDATA[$F{imagePath} == null]]></printWhenExpression>
                    </reportElement>
                    <textElement textAlignment="Center" verticalAlignment="Middle">
                        <font size="9"/>
                    </textElement>
                    <text><![CDATA[لا توجد صورة]]></text>
                </staticText>

            </frame>

        </band>

    </detail>

</jasperReport>