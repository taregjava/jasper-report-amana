<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="project_start_report_building"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="0"
              bottomMargin="0"
              language="java">

    <property name="net.sf.jasperreports.text.direction" value="RTL"/>
    <style name="Default" isDefault="true" fontName="Arial" pdfFontName="fonts/ARIAL.TTF" pdfEncoding="Identity-H" isPdfEmbedded="true"/>

    <!-- BuildingInfo DTO parameters -->
    <parameter name="buildingType" class="java.lang.String"/>
    <parameter name="otherBuildingType" class="java.lang.String"/>
    <parameter name="buildingDescription" class="java.lang.String"/>
    <parameter name="isFullyFinished" class="java.lang.Boolean"/>
    <parameter name="isPartiallyBuilt" class="java.lang.Boolean"/>
    <parameter name="landNumber" class="java.lang.String"/>
    <parameter name="blockNumber" class="java.lang.String"/>
    <parameter name="pieceNumber" class="java.lang.String"/>
    <parameter name="floorsCount" class="java.lang.String"/>
    <parameter name="planNumber" class="java.lang.String"/>
    <parameter name="licenseNumber" class="java.lang.String"/>
    <parameter name="licenseDate" class="java.lang.String"/>
    <parameter name="areaByDeed" class="java.lang.Double"/>
    <parameter name="areaByLicense" class="java.lang.Double"/>
    <parameter name="areaByNature" class="java.lang.Double"/>
    <parameter name="sector" class="java.lang.String"/>
    <parameter name="district" class="java.lang.String"/>
    <parameter name="street" class="java.lang.String"/>

    <title>
        <band height="160">
            <!-- Row 1: title -->
            <staticText>
                <reportElement x="1" y="0" width="800" height="24" mode="Opaque" backcolor="#005B41" forecolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="12" isBold="true"/></textElement>
                <text><![CDATA[معلومات المبنى]]></text>
            </staticText>

            <!-- Row 2: right half type / left half condition -->
            <line>
                <reportElement x="401" y="24" width="0" height="30"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#000000"/></graphicElement>
            </line>

            <staticText>
                <reportElement x="701" y="24" width="100" height="30" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[نوع المبنى]]></text>
            </staticText>
            <textField>
                <reportElement x="401" y="24" width="300" height="30" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[
($P{buildingType} == null ? "" : $P{buildingType})
 + " | سكني | تجاري | صناعي | أخرى يحدد: "
 + ($P{otherBuildingType} == null ? "................" : $P{otherBuildingType})
                ]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="301" y="24" width="100" height="30" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[حالة البناء]]></text>
            </staticText>
            <frame>
                <reportElement x="1" y="24" width="300" height="30" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <rectangle>
                    <reportElement x="206" y="10" width="10" height="10" mode="Opaque" backcolor="#FFFFFF"/>
                    <graphicElement><pen lineWidth="0.5" lineColor="#000000"/></graphicElement>
                </rectangle>
                <textField>
                    <reportElement x="205" y="8" width="12" height="12"/>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                    <textFieldExpression><![CDATA[Boolean.TRUE.equals($P{isFullyFinished}) ? "✓" : ""]]></textFieldExpression>
                </textField>
                <staticText>
                    <reportElement x="220" y="9" width="75" height="12"/>
                    <textElement textAlignment="Right" verticalAlignment="Middle"><font size="9"/></textElement>
                    <text><![CDATA[مبنية بالكامل]]></text>
                </staticText>

                <rectangle>
                    <reportElement x="74" y="10" width="10" height="10" mode="Opaque" backcolor="#FFFFFF"/>
                    <graphicElement><pen lineWidth="0.5" lineColor="#000000"/></graphicElement>
                </rectangle>
                <textField>
                    <reportElement x="73" y="8" width="12" height="12"/>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                    <textFieldExpression><![CDATA[Boolean.TRUE.equals($P{isPartiallyBuilt}) ? "✓" : ""]]></textFieldExpression>
                </textField>
                <staticText>
                    <reportElement x="88" y="9" width="95" height="12"/>
                    <textElement textAlignment="Right" verticalAlignment="Middle"><font size="9"/></textElement>
                    <text><![CDATA[جزء من المباني]]></text>
                </staticText>
            </frame>

            <!-- Row 3: description -->
            <staticText>
                <reportElement x="701" y="54" width="100" height="28" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[وصف البناء]]></text>
            </staticText>
            <textField textAdjust="StretchHeight">
                <reportElement x="1" y="54" width="700" height="28" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{buildingDescription}]]></textFieldExpression>
            </textField>

            <!-- Row 4: license + middle 4 fields + area(3x60) -->
            <staticText>
                <reportElement x="681" y="82" width="120" height="24" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[رقم رخصة البناء]]></text>
            </staticText>
            <textField>
                <reportElement x="581" y="82" width="100" height="24" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{licenseNumber}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="481" y="82" width="100" height="24" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[تاريخها]]></text>
            </staticText>
            <staticText>
                <reportElement x="381" y="82" width="100" height="24" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[رقم المخطط]]></text>
            </staticText>
            <staticText>
                <reportElement x="281" y="82" width="100" height="24" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[رقم القطعة]]></text>
            </staticText>
            <staticText>
                <reportElement x="181" y="82" width="100" height="24" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[عدد الطوابق]]></text>
            </staticText>

            <staticText>
                <reportElement x="121" y="82" width="60" height="24" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[حسب الصك]]></text>
            </staticText>
            <staticText>
                <reportElement x="61" y="82" width="60" height="24" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[حسب الرخصة]]></text>
            </staticText>
            <staticText>
                <reportElement x="1" y="82" width="60" height="24" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[حسب الطبيعة]]></text>
            </staticText>

            <textField>
                <reportElement x="481" y="106" width="100" height="24" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{licenseDate}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="381" y="106" width="100" height="24" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{planNumber}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="281" y="106" width="100" height="24" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{pieceNumber}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="181" y="106" width="100" height="24" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{floorsCount}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="121" y="106" width="60" height="24" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$P{areaByDeed} == null ? "" : String.valueOf($P{areaByDeed})]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="61" y="106" width="60" height="24" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$P{areaByLicense} == null ? "" : String.valueOf($P{areaByLicense})]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="106" width="60" height="24" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$P{areaByNature} == null ? "" : String.valueOf($P{areaByNature})]]></textFieldExpression>
            </textField>

            <!-- Row 5: location -->
            <staticText>
                <reportElement x="701" y="130" width="100" height="26" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[القطاع]]></text>
            </staticText>
            <textField>
                <reportElement x="501" y="130" width="200" height="26" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{sector}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="401" y="130" width="100" height="26" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[الحي]]></text>
            </staticText>
            <textField>
                <reportElement x="251" y="130" width="150" height="26" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{district}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="151" y="130" width="100" height="26" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[الشارع]]></text>
            </staticText>
            <textField>
                <reportElement x="1" y="130" width="150" height="26" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{street}]]></textFieldExpression>
            </textField>
        </band>
    </title>

</jasperReport>

