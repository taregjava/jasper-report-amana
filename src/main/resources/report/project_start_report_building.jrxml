<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="project_start_report_building"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="0"
              bottomMargin="0"
              language="java">

    <property name="net.sf.jasperreports.text.direction" value="RTL"/>
    <style name="Default" isDefault="true" fontName="Arial" pdfFontName="fonts/ARIAL.TTF" pdfEncoding="Identity-H" isPdfEmbedded="true"/>

    <!-- BuildingInfo DTO parameters -->
    <parameter name="buildingType" class="java.lang.String"/>
    <parameter name="buildingDescription" class="java.lang.String"/>
    <parameter name="isFullyFinished" class="java.lang.Boolean"/>
    <parameter name="isPartiallyBuilt" class="java.lang.Boolean"/>
    <parameter name="landNumber" class="java.lang.String"/>
    <parameter name="blockNumber" class="java.lang.String"/>
    <parameter name="planNumber" class="java.lang.String"/>
    <parameter name="licenseNumber" class="java.lang.String"/>
    <parameter name="licenseDate" class="java.lang.String"/>
    <parameter name="district" class="java.lang.String"/>
    <parameter name="street" class="java.lang.String"/>

    <title>
        <band height="140">
            <!-- row 1: merged main title -->
            <staticText>
                <reportElement x="1" y="0" width="800" height="24" mode="Opaque" backcolor="#005B41" forecolor="#FFFFFF"/>
                <box>
                    <pen lineWidth="0.5" lineColor="#000000"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" pdfFontName="fonts/ARIAL.TTF" size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[معلومات المبنى]]></text>
            </staticText>

            <!-- row 2: building type + checkboxes -->
            <staticText>
                <reportElement x="1" y="24" width="100" height="22" mode="Opaque" backcolor="#E8F5E9" forecolor="#000000"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[نوع المبنى]]></text>
            </staticText>
            <textField>
                <reportElement x="101" y="24" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{buildingType}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="201" y="24" width="100" height="22" mode="Opaque" backcolor="#E8F5E9" forecolor="#000000"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[مبني بالكامل]]></text>
            </staticText>
            <frame>
                <reportElement x="301" y="24" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <rectangle>
                    <reportElement x="45" y="6" width="10" height="10" mode="Opaque" backcolor="#FFFFFF"/>
                    <graphicElement><pen lineWidth="0.5" lineColor="#000000"/></graphicElement>
                </rectangle>
                <textField>
                    <reportElement x="44" y="3" width="12" height="14"/>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                    <textFieldExpression><![CDATA[Boolean.TRUE.equals($P{isFullyFinished}) ? "✓" : ""]]></textFieldExpression>
                </textField>
            </frame>

            <staticText>
                <reportElement x="401" y="24" width="100" height="22" mode="Opaque" backcolor="#E8F5E9" forecolor="#000000"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[جزء من المباني]]></text>
            </staticText>
            <frame>
                <reportElement x="501" y="24" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <rectangle>
                    <reportElement x="45" y="6" width="10" height="10" mode="Opaque" backcolor="#FFFFFF"/>
                    <graphicElement><pen lineWidth="0.5" lineColor="#000000"/></graphicElement>
                </rectangle>
                <textField>
                    <reportElement x="44" y="3" width="12" height="14"/>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                    <textFieldExpression><![CDATA[Boolean.TRUE.equals($P{isPartiallyBuilt}) ? "✓" : ""]]></textFieldExpression>
                </textField>
            </frame>

            <staticText>
                <reportElement x="601" y="24" width="100" height="22" mode="Opaque" backcolor="#E8F5E9" forecolor="#000000"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[الحي]]></text>
            </staticText>
            <textField>
                <reportElement x="701" y="24" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{district}]]></textFieldExpression>
            </textField>

            <!-- row 3: numbered plot/license details -->
            <staticText>
                <reportElement x="1" y="46" width="100" height="22" mode="Opaque" backcolor="#E8F5E9" forecolor="#000000"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[رقم الأرض]]></text>
            </staticText>
            <textField>
                <reportElement x="101" y="46" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{landNumber}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="201" y="46" width="100" height="22" mode="Opaque" backcolor="#E8F5E9" forecolor="#000000"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[رقم البلك]]></text>
            </staticText>
            <textField>
                <reportElement x="301" y="46" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{blockNumber}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="401" y="46" width="100" height="22" mode="Opaque" backcolor="#E8F5E9" forecolor="#000000"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[رقم المخطط]]></text>
            </staticText>
            <textField>
                <reportElement x="501" y="46" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{planNumber}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="601" y="46" width="100" height="22" mode="Opaque" backcolor="#E8F5E9" forecolor="#000000"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[الشارع]]></text>
            </staticText>
            <textField>
                <reportElement x="701" y="46" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{street}]]></textFieldExpression>
            </textField>

            <!-- row 4: license data -->
            <staticText>
                <reportElement x="1" y="68" width="100" height="22" mode="Opaque" backcolor="#E8F5E9" forecolor="#000000"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[رقم الرخصة]]></text>
            </staticText>
            <textField>
                <reportElement x="101" y="68" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{licenseNumber}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="201" y="68" width="100" height="22" mode="Opaque" backcolor="#E8F5E9" forecolor="#000000"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[تاريخ الرخصة]]></text>
            </staticText>
            <textField>
                <reportElement x="301" y="68" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{licenseDate}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="401" y="68" width="100" height="22" mode="Opaque" backcolor="#E8F5E9" forecolor="#000000"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[البيان]]></text>
            </staticText>
            <textField>
                <reportElement x="501" y="68" width="300" height="22" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[Boolean.TRUE.equals($P{isFullyFinished}) ? "مبني بالكامل" : (Boolean.TRUE.equals($P{isPartiallyBuilt}) ? "جزء من المباني في الرخصة" : "")]]></textFieldExpression>
            </textField>

            <!-- row 5: merged description -->
            <staticText>
                <reportElement x="1" y="90" width="100" height="48" mode="Opaque" backcolor="#E8F5E9" forecolor="#000000"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[وصف البناء]]></text>
            </staticText>
            <textField textAdjust="StretchHeight">
                <reportElement x="101" y="90" width="700" height="48" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{buildingDescription}]]></textFieldExpression>
            </textField>
        </band>
    </title>

</jasperReport>

