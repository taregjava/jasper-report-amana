<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="inspection_conditions_flat"
              pageWidth="802"
              pageHeight="600"
              columnWidth="802"
              leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">

    <parameter name="conditionImageRows" class="net.sf.jasperreports.engine.JRDataSource"/>

    <field name="rowNumber" class="java.lang.Integer"/>
    <field name="title" class="java.lang.String"/>
    <field name="conditionText" class="java.lang.String"/>
    <field name="imagePath" class="java.lang.Object"/>
    <field name="noteText" class="java.lang.String"/>

    <detail>
        <band height="200">

            <frame>
                <reportElement x="0" y="0" width="802" height="200"/>
                <box><pen lineWidth="0.5"/></box>

                <!-- TITLE -->
                <textField isStretchWithOverflow="true">
                    <reportElement x="5" y="5" width="335" height="20" positionType="Float" mode="Opaque" backcolor="#DDDDDD"/>
                    <textElement textAlignment="Center">
                        <font pdfFontName="fonts/Amiri-Regular.ttf"
                              pdfEncoding="Identity-H"
                              isPdfEmbedded="true"
                              size="10"
                              isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA[
                    $F{title} != null && !$F{title}.trim().isEmpty()
                    ? $F{title}
                    : $F{title}
                ]]></textFieldExpression>
                </textField>

                <!-- NOTE -->
                <textField isStretchWithOverflow="true">
                    <reportElement x="5" y="35" width="335" height="143" positionType="Float"/>
                    <textElement textAlignment="Right">
                        <font pdfFontName="fonts/Amiri-Regular.ttf"
                              pdfEncoding="Identity-H"
                              isPdfEmbedded="true"
                              size="10"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$F{noteText}]]></textFieldExpression>
                </textField>

                <!-- Vertical separator -->
                <line>
                    <reportElement x="348" y="5" width="0" height="190"/>
                    <graphicElement>
                        <pen lineWidth="0.5" lineColor="#CCCCCC"/>
                    </graphicElement>
                </line>

                <!-- Image cell background — maximum size -->
                <rectangle>
                    <reportElement x="352" y="3" width="447" height="194" mode="Opaque" backcolor="#F8F8F8"/>
                    <graphicElement>
                        <pen lineWidth="0.5" lineColor="#DDDDDD"/>
                    </graphicElement>
                </rectangle>

                <!-- IMAGE — maximum size, centered -->
                <image scaleImage="RetainShape" hAlign="Center" vAlign="Middle">
                    <reportElement x="356" y="6" width="439" height="188" positionType="Float">
                        <printWhenExpression><![CDATA[$F{imagePath} != null]]></printWhenExpression>
                    </reportElement>
                    <imageExpression class="java.lang.Object"><![CDATA[$F{imagePath}]]></imageExpression>
                </image>

                <!-- Placeholder text when no image -->
                <staticText>
                    <reportElement x="352" y="3" width="447" height="194" forecolor="#AAAAAA" mode="Transparent">
                        <printWhenExpression><![CDATA[$F{imagePath} == null]]></printWhenExpression>
                    </reportElement>
                    <textElement textAlignment="Center" verticalAlignment="Middle">
                        <font pdfFontName="fonts/Amiri-Regular.ttf"
                              pdfEncoding="Identity-H"
                              isPdfEmbedded="true"
                              size="9"/>
                    </textElement>
                    <text><![CDATA[لا توجد صورة]]></text>
                </staticText>

            </frame>

        </band>
    </detail>

</jasperReport>
