<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="project_start_report_master"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20"
              language="java">

    <property name="net.sf.jasperreports.text.direction" value="RTL"/>
    <style name="Default" isDefault="true" fontName="SansSerif" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>

    <!-- Subreport parameters (compiled JasperReport instances) -->
    <parameter name="headerSubreport" class="net.sf.jasperreports.engine.JasperReport"/>
    <parameter name="bodySubreport" class="net.sf.jasperreports.engine.JasperReport"/>
    <parameter name="buildingSubreport" class="net.sf.jasperreports.engine.JasperReport"/>
    <parameter name="tableSubreport" class="net.sf.jasperreports.engine.JasperReport"/>

    <!-- datasource for tasks table -->
    <parameter name="tableData" class="net.sf.jasperreports.engine.JRDataSource"/>

    <!-- propagate other header/body params as needed (declare commonly used ones) -->
    <parameter name="reportLogo" class="java.lang.Object"/>
    <parameter name="projectNameAndAddress" class="java.lang.String"/>
    <parameter name="reportDate" class="java.lang.String"/>
    <!-- Building params forwarded to building subreport -->
    <parameter name="buildingType" class="java.lang.String"/>
    <parameter name="buildingCondition" class="java.lang.String"/>
    <parameter name="buildingDescription" class="java.lang.String"/>
    <parameter name="licenseNumber" class="java.lang.String"/>
    <parameter name="licenseDate" class="java.lang.String"/>
    <parameter name="planNumber" class="java.lang.String"/>
    <parameter name="district" class="java.lang.String"/>
    <parameter name="street" class="java.lang.String"/>
    <parameter name="landNumber" class="java.lang.String"/>
    <parameter name="blockNumber" class="java.lang.String"/>
    <parameter name="isFullyFinished" class="java.lang.Boolean"/>
    <parameter name="isPartiallyBuilt" class="java.lang.Boolean"/>
    <!-- Owner params forwarded to body subreport -->
    <parameter name="ownerName" class="java.lang.String"/>
    <parameter name="ownerIdNumber" class="java.lang.String"/>
    <parameter name="ownerMobile" class="java.lang.String"/>
    <parameter name="deedNumber" class="java.lang.String"/>
    <parameter name="supervisingEngineeringOffice" class="java.lang.String"/>
    <parameter name="designingEngineeringOffice" class="java.lang.String"/>
    <parameter name="contractorName" class="java.lang.String"/>
    <parameter name="contractorRecord" class="java.lang.String"/>
    <parameter name="contractorMobile" class="java.lang.String"/>
    <parameter name="supervisingEngineerName" class="java.lang.String"/>
    <parameter name="stageInspectionResult" class="java.lang.String"/>
    <parameter name="stageInspectionNotes" class="java.lang.String"/>
    <!-- compiled owner subreport JasperReport instance -->
    <parameter name="ownerSubreport" class="net.sf.jasperreports.engine.JasperReport"/>

    <title>
        <band height="10"/>
    </title>

    <detail>
        <!-- adjust detail band height so compiled subreport placements fit the page height -->
        <!-- pageHeight(595) - topMargin(20) - bottomMargin(20) - title(10) = 545 -->
        <band height="545">
            <!-- header subreport placed at top -->
            <subreport>
                <reportElement x="0" y="0" width="802" height="200"/>
                <subreportParameter name="reportLogo">
                    <subreportParameterExpression><![CDATA[$P{reportLogo}]]></subreportParameterExpression>
                </subreportParameter>
                <subreportParameter name="projectNameAndAddress">
                    <subreportParameterExpression><![CDATA[$P{projectNameAndAddress}]]></subreportParameterExpression>
                </subreportParameter>
                <subreportParameter name="reportDate">
                    <subreportParameterExpression><![CDATA[$P{reportDate}]]></subreportParameterExpression>
                </subreportParameter>
                <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.JREmptyDataSource(1)]]></dataSourceExpression>
                <subreportExpression class="net.sf.jasperreports.engine.JasperReport"><![CDATA[$P{headerSubreport}]]></subreportExpression>
            </subreport>

            <!-- ownership subreport (separate file) -->
            <subreport>
                <reportElement x="0" y="210" width="802" height="176"/>
                <!-- pass ownership parameters into owner subreport -->
                <subreportParameter name="ownerName"><subreportParameterExpression><![CDATA[$P{ownerName}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="ownerIdNumber"><subreportParameterExpression><![CDATA[$P{ownerIdNumber}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="ownerMobile"><subreportParameterExpression><![CDATA[$P{ownerMobile}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="deedNumber"><subreportParameterExpression><![CDATA[$P{deedNumber}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="supervisingEngineeringOffice"><subreportParameterExpression><![CDATA[$P{supervisingEngineeringOffice}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="designingEngineeringOffice"><subreportParameterExpression><![CDATA[$P{designingEngineeringOffice}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="contractorName"><subreportParameterExpression><![CDATA[$P{contractorName}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="contractorRecord"><subreportParameterExpression><![CDATA[$P{contractorRecord}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="contractorMobile"><subreportParameterExpression><![CDATA[$P{contractorMobile}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="reportDate"><subreportParameterExpression><![CDATA[$P{reportDate}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="projectNameAndAddress"><subreportParameterExpression><![CDATA[$P{projectNameAndAddress}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="supervisingEngineerName"><subreportParameterExpression><![CDATA[$P{supervisingEngineerName}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="stageInspectionResult"><subreportParameterExpression><![CDATA[$P{stageInspectionResult}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="stageInspectionNotes"><subreportParameterExpression><![CDATA[$P{stageInspectionNotes}]]></subreportParameterExpression></subreportParameter>
                <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.JREmptyDataSource(1)]]></dataSourceExpression>
                <subreportExpression class="net.sf.jasperreports.engine.JasperReport"><![CDATA[$P{ownerSubreport}]]></subreportExpression>
            </subreport>

            <!-- building subreport (separate file) -->
            <subreport>
                <!-- positioned below header+owner; reduced height so all bands fit on page -->
                <reportElement x="0" y="400" width="802" height="140"/>
                <subreportParameter name="buildingType"><subreportParameterExpression><![CDATA[$P{buildingType}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="buildingDescription"><subreportParameterExpression><![CDATA[$P{buildingDescription}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="licenseNumber"><subreportParameterExpression><![CDATA[$P{licenseNumber}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="licenseDate"><subreportParameterExpression><![CDATA[$P{licenseDate}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="planNumber"><subreportParameterExpression><![CDATA[$P{planNumber}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="district"><subreportParameterExpression><![CDATA[$P{district}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="street"><subreportParameterExpression><![CDATA[$P{street}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="landNumber"><subreportParameterExpression><![CDATA[$P{landNumber}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="blockNumber"><subreportParameterExpression><![CDATA[$P{blockNumber}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="isFullyFinished"><subreportParameterExpression><![CDATA[$P{isFullyFinished}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="isPartiallyBuilt"><subreportParameterExpression><![CDATA[$P{isPartiallyBuilt}]]></subreportParameterExpression></subreportParameter>
                <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.JREmptyDataSource(1)]]></dataSourceExpression>
                <subreportExpression class="net.sf.jasperreports.engine.JasperReport"><![CDATA[$P{buildingSubreport}]]></subreportExpression>
            </subreport>

        </band>
    </detail>

    <summary>
        <band height="90">
            <!-- table subreport moved to summary to free first-page space for owner + building -->
            <subreport>
                <reportElement x="0" y="0" width="802" height="80"/>
                <dataSourceExpression><![CDATA[$P{tableData}]]></dataSourceExpression>
                <subreportExpression class="net.sf.jasperreports.engine.JasperReport"><![CDATA[$P{tableSubreport}]]></subreportExpression>
            </subreport>
        </band>
    </summary>

</jasperReport>

