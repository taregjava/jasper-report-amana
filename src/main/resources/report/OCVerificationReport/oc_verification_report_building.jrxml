<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="oc_verification_report_building"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="0"
              bottomMargin="0"
              language="java">

    <property name="net.sf.jasperreports.text.direction" value="RTL"/>
    <style name="Default" isDefault="true" fontName="Arial" pdfFontName="fonts/ARIAL.TTF" pdfEncoding="Identity-H" isPdfEmbedded="true"/>

    <!-- BuildingInfo DTO parameters -->
    <parameter name="buildingType" class="java.lang.String"/>
    <parameter name="buildingTypeResidential" class="java.lang.Boolean"/>
    <parameter name="buildingTypeResidentialCommercial" class="java.lang.Boolean"/>
    <parameter name="buildingTypeCommercial" class="java.lang.Boolean"/>
    <parameter name="buildingTypeVilla" class="java.lang.Boolean"/>
    <parameter name="buildingTypeOther" class="java.lang.Boolean"/>
    <parameter name="otherBuildingType" class="java.lang.String"/>
    <parameter name="isFullyFinished" class="java.lang.Boolean"/>
    <parameter name="isPartiallyBuilt" class="java.lang.Boolean"/>
    <parameter name="pieceNumber" class="java.lang.String"/>
    <parameter name="floorsCount" class="java.lang.String"/>
    <parameter name="planNumber" class="java.lang.String"/>
    <parameter name="licenseNumber" class="java.lang.String"/>
    <parameter name="licenseDate" class="java.lang.String"/>
    <parameter name="areaByDeed" class="java.lang.Double"/>
    <parameter name="areaByLicense" class="java.lang.Double"/>
    <parameter name="areaByNature" class="java.lang.Double"/>
    <parameter name="sector" class="java.lang.String"/>
    <parameter name="district" class="java.lang.String"/>
    <parameter name="street" class="java.lang.String"/>
    <parameter name="stageInspectionAccepted" class="java.lang.Boolean"/>
    <parameter name="stageInspectionRejected" class="java.lang.Boolean"/>

    <title>
        <band height="112">
            <!-- Header -->
            <staticText>
                <reportElement x="1" y="0" width="800" height="24" mode="Opaque" backcolor="#005B41" forecolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[معلومات المبنى]]></text>
            </staticText>

            <!-- Row 2: building type + build state -->
            <staticText>
                <reportElement x="701" y="24" width="100" height="24" mode="Opaque" backcolor="#E8F5E9"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[نوع المبنى]]></text>
            </staticText>
            <frame>
                <reportElement x="381" y="24" width="320" height="24" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>

                <rectangle><reportElement x="286" y="7" width="10" height="10"/><graphicElement><pen lineWidth="0.5"/></graphicElement></rectangle>
                <textField><reportElement x="285" y="5" width="12" height="12"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><textFieldExpression><![CDATA[Boolean.TRUE.equals($P{buildingTypeResidential}) ? "X" : ""]]></textFieldExpression></textField>
                <staticText><reportElement x="251" y="6" width="32" height="12"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement><text><![CDATA[سكني]]></text></staticText>

                <rectangle><reportElement x="216" y="7" width="10" height="10"/><graphicElement><pen lineWidth="0.5"/></graphicElement></rectangle>
                <textField><reportElement x="215" y="5" width="12" height="12"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><textFieldExpression><![CDATA[Boolean.TRUE.equals($P{buildingTypeCommercial}) ? "X" : ""]]></textFieldExpression></textField>
                <staticText><reportElement x="175" y="6" width="38" height="12"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement><text><![CDATA[تجاري]]></text></staticText>

                <rectangle><reportElement x="142" y="7" width="10" height="10"/><graphicElement><pen lineWidth="0.5"/></graphicElement></rectangle>
                <textField><reportElement x="141" y="5" width="12" height="12"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><textFieldExpression><![CDATA[Boolean.TRUE.equals($P{buildingTypeResidentialCommercial}) ? "X" : ""]]></textFieldExpression></textField>
                <staticText><reportElement x="84" y="6" width="54" height="12"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement><text><![CDATA[سكني-تجاري]]></text></staticText>

                <rectangle><reportElement x="63" y="7" width="10" height="10"/><graphicElement><pen lineWidth="0.5"/></graphicElement></rectangle>
                <textField><reportElement x="62" y="5" width="12" height="12"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><textFieldExpression><![CDATA[Boolean.TRUE.equals($P{buildingTypeVilla}) ? "X" : ""]]></textFieldExpression></textField>
                <staticText><reportElement x="36" y="6" width="24" height="12"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement><text><![CDATA[فيلا]]></text></staticText>

                <rectangle><reportElement x="18" y="7" width="10" height="10"/><graphicElement><pen lineWidth="0.5"/></graphicElement></rectangle>
                <textField><reportElement x="17" y="5" width="12" height="12"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><textFieldExpression><![CDATA[(Boolean.TRUE.equals($P{buildingTypeOther}) || ($P{otherBuildingType} != null && !$P{otherBuildingType}.trim().isEmpty())) ? "X" : ""]]></textFieldExpression></textField>
                <staticText><reportElement x="1" y="6" width="16" height="12"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement><text><![CDATA[أخرى]]></text></staticText>
            </frame>

            <staticText>
                <reportElement x="301" y="24" width="80" height="24" mode="Opaque" backcolor="#E8F5E9"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[حالة البناء على الرخصة]]></text>
            </staticText>
            <frame>
                <reportElement x="1" y="24" width="300" height="24" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <rectangle><reportElement x="196" y="7" width="10" height="10"/><graphicElement><pen lineWidth="0.5"/></graphicElement></rectangle>
                <textField><reportElement x="195" y="5" width="12" height="12"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><textFieldExpression><![CDATA[Boolean.TRUE.equals($P{isFullyFinished}) ? "X" : ""]]></textFieldExpression></textField>
                <staticText><reportElement x="124" y="6" width="70" height="12"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement><text><![CDATA[مبنية بالكامل]]></text></staticText>
                <rectangle><reportElement x="82" y="7" width="10" height="10"/><graphicElement><pen lineWidth="0.5"/></graphicElement></rectangle>
                <textField><reportElement x="81" y="5" width="12" height="12"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><textFieldExpression><![CDATA[Boolean.TRUE.equals($P{isPartiallyBuilt}) ? "X" : ""]]></textFieldExpression></textField>
                <staticText><reportElement x="1" y="6" width="78" height="12"/><textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement><text><![CDATA[جزء من المبنى في الرخصة]]></text></staticText>
            </frame>

            <!-- Row 3: technical headers -->
            <staticText><reportElement x="701" y="48" width="100" height="22" mode="Opaque" backcolor="#E8F5E9"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[رقم رخصة البناء]]></text></staticText>
            <staticText><reportElement x="601" y="48" width="100" height="22" mode="Opaque" backcolor="#E8F5E9"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[تاريخها]]></text></staticText>
            <staticText><reportElement x="501" y="48" width="100" height="22" mode="Opaque" backcolor="#E8F5E9"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[رقم المخطط]]></text></staticText>
            <staticText><reportElement x="401" y="48" width="100" height="22" mode="Opaque" backcolor="#E8F5E9"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[رقم القطعة]]></text></staticText>
            <staticText><reportElement x="301" y="48" width="100" height="22" mode="Opaque" backcolor="#E8F5E9"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[عدد الطوابق]]></text></staticText>
            <staticText><reportElement x="1" y="48" width="300" height="11" mode="Opaque" backcolor="#E8F5E9"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[مساحة الأرض]]></text></staticText>
            <staticText><reportElement x="201" y="59" width="100" height="11" mode="Opaque" backcolor="#E8F5E9"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="7" isBold="true"/></textElement><text><![CDATA[حسب الصك]]></text></staticText>
            <staticText><reportElement x="101" y="59" width="100" height="11" mode="Opaque" backcolor="#E8F5E9"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="7" isBold="true"/></textElement><text><![CDATA[حسب الرخصة]]></text></staticText>
            <staticText><reportElement x="1" y="59" width="100" height="11" mode="Opaque" backcolor="#E8F5E9"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="7" isBold="true"/></textElement><text><![CDATA[حسب الطبيعة]]></text></staticText>

            <!-- Row 4: technical values -->
            <textField isBlankWhenNull="true"><reportElement x="701" y="70" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA[$P{licenseNumber}]]></textFieldExpression></textField>
            <textField isBlankWhenNull="true"><reportElement x="601" y="70" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA[$P{licenseDate}]]></textFieldExpression></textField>
            <textField isBlankWhenNull="true"><reportElement x="501" y="70" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA[$P{planNumber}]]></textFieldExpression></textField>
            <textField isBlankWhenNull="true"><reportElement x="401" y="70" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA[$P{pieceNumber}]]></textFieldExpression></textField>
            <textField isBlankWhenNull="true"><reportElement x="301" y="70" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA[$P{floorsCount}]]></textFieldExpression></textField>
            <textField isBlankWhenNull="true"><reportElement x="201" y="70" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA[$P{areaByDeed} == null ? "" : new java.text.DecimalFormat("#,##0.##").format($P{areaByDeed})]]></textFieldExpression></textField>
            <textField isBlankWhenNull="true"><reportElement x="101" y="70" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA[$P{areaByLicense} == null ? "" : new java.text.DecimalFormat("#,##0.##").format($P{areaByLicense})]]></textFieldExpression></textField>
            <textField isBlankWhenNull="true"><reportElement x="1" y="70" width="100" height="22" mode="Opaque" backcolor="#FFFFFF"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA[$P{areaByNature} == null ? "" : new java.text.DecimalFormat("#,##0.##").format($P{areaByNature})]]></textFieldExpression></textField>

            <!-- Row 5: sector / district / street + supervisor result -->
            <staticText><reportElement x="701" y="92" width="100" height="20" mode="Opaque" backcolor="#E8F5E9"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[نتيجة فحص المكتب المشرف]]></text></staticText>
            <frame>
                <reportElement x="601" y="92" width="100" height="20" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5"/></box>
                <rectangle><reportElement x="8" y="5" width="10" height="10"/><graphicElement><pen lineWidth="0.5"/></graphicElement></rectangle>
                <textField><reportElement x="7" y="4" width="12" height="12"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><textFieldExpression><![CDATA[Boolean.TRUE.equals($P{stageInspectionAccepted}) ? "X" : ""]]></textFieldExpression></textField>
                <staticText><reportElement x="22" y="5" width="28" height="10"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="7"/></textElement><text><![CDATA[مطابق]]></text></staticText>
                <rectangle><reportElement x="52" y="5" width="10" height="10"/><graphicElement><pen lineWidth="0.5"/></graphicElement></rectangle>
                <textField><reportElement x="51" y="4" width="12" height="12"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><textFieldExpression><![CDATA[Boolean.TRUE.equals($P{stageInspectionRejected}) ? "X" : ""]]></textFieldExpression></textField>
                <staticText><reportElement x="66" y="5" width="28" height="10"/><textElement textAlignment="Center" verticalAlignment="Middle"><font size="7"/></textElement><text><![CDATA[غير مطابق]]></text></staticText>
            </frame>

            <staticText><reportElement x="501" y="92" width="100" height="20" mode="Opaque" backcolor="#E8F5E9"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[القطاع]]></text></staticText>
            <textField isBlankWhenNull="true"><reportElement x="401" y="92" width="100" height="20" mode="Opaque" backcolor="#FFFFFF"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA[$P{sector}]]></textFieldExpression></textField>
            <staticText><reportElement x="301" y="92" width="100" height="20" mode="Opaque" backcolor="#E8F5E9"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[الحي]]></text></staticText>
            <textField isBlankWhenNull="true"><reportElement x="201" y="92" width="100" height="20" mode="Opaque" backcolor="#FFFFFF"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA[$P{district}]]></textFieldExpression></textField>
            <staticText><reportElement x="101" y="92" width="100" height="20" mode="Opaque" backcolor="#E8F5E9"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement><text><![CDATA[الشارع]]></text></staticText>
            <textField isBlankWhenNull="true"><reportElement x="1" y="92" width="100" height="20" mode="Opaque" backcolor="#FFFFFF"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement><textFieldExpression><![CDATA[$P{street}]]></textFieldExpression></textField>
        </band>
    </title>

</jasperReport>

