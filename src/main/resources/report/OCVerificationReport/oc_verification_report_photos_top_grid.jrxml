<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="oc_verification_report_photos_top_grid"
              pageWidth="802"
              pageHeight="200"
              columnCount="2"
              printOrder="Horizontal"
              columnWidth="401"
              leftMargin="0"
              rightMargin="0"
              topMargin="0"
              bottomMargin="0"
              whenNoDataType="AllSectionsNoDetail"
              language="java">

    <property name="net.sf.jasperreports.text.direction" value="RTL"/>
    <style name="Default" isDefault="true" fontName="SansSerif" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>

    <field name="title" class="java.lang.String"/>
    <field name="image" class="java.lang.Object"/>

    <detail>
        <band height="94">
            <staticText>
                <reportElement x="0" y="0" width="401" height="20" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <text><![CDATA[]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="4" y="2" width="393" height="16"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{title}]]></textFieldExpression>
            </textField>

            <frame>
                <reportElement x="0" y="20" width="401" height="74" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <image scaleImage="RetainShape" hAlign="Center" vAlign="Middle">
                    <reportElement x="3" y="3" width="395" height="68">
                        <printWhenExpression><![CDATA[$F{image} != null]]></printWhenExpression>
                    </reportElement>
                    <imageExpression class="java.lang.Object"><![CDATA[$F{image}]]></imageExpression>
                </image>
                <staticText>
                    <reportElement x="3" y="3" width="395" height="68" forecolor="#999999">
                        <printWhenExpression><![CDATA[$F{image} == null]]></printWhenExpression>
                    </reportElement>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                    <text><![CDATA[لا توجد صورة]]></text>
                </staticText>
            </frame>
        </band>
    </detail>

</jasperReport>


