<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="oc_verification_report_photos"
              pageWidth="842"
              pageHeight="555"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="0"
              bottomMargin="0"
              language="java">

    <property name="net.sf.jasperreports.text.direction" value="RTL"/>
    <style name="Default" isDefault="true" fontName="SansSerif" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>

    <parameter name="headerSubreport" class="net.sf.jasperreports.engine.JasperReport"/>
    <parameter name="topGridSubreport" class="net.sf.jasperreports.engine.JasperReport"/>
    <parameter name="bottomGridSubreport" class="net.sf.jasperreports.engine.JasperReport"/>
    <parameter name="topGridData" class="net.sf.jasperreports.engine.JRDataSource"/>
    <parameter name="bottomGridData" class="net.sf.jasperreports.engine.JRDataSource"/>
    <parameter name="reportLogo" class="java.lang.Object"/>
    <parameter name="projectNameAndAddress" class="java.lang.String"/>
    <parameter name="reportDate" class="java.lang.String"/>

    <parameter name="spatialPortalPhoto" class="java.lang.Object"/>
    <parameter name="implementationPhoto" class="java.lang.Object"/>
    <parameter name="aerialPhoto" class="java.lang.Object"/>
    <parameter name="implementationPhoto1" class="java.lang.Object"/>
    <parameter name="implementationPhoto2" class="java.lang.Object"/>
    <parameter name="implementationPhoto3" class="java.lang.Object"/>
    <parameter name="implementationPhoto4" class="java.lang.Object"/>
    <parameter name="detailPhoto1" class="java.lang.Object"/>
    <parameter name="detailPhoto2" class="java.lang.Object"/>
    <parameter name="detailPhoto3" class="java.lang.Object"/>
    <parameter name="detailPhoto4" class="java.lang.Object"/>
    <parameter name="detailPhoto5" class="java.lang.Object"/>
    <parameter name="detailPhoto6" class="java.lang.Object"/>
    <parameter name="detailDescription1" class="java.lang.String"/>
    <parameter name="detailDescription2" class="java.lang.String"/>
    <parameter name="detailDescription3" class="java.lang.String"/>
    <parameter name="detailDescription4" class="java.lang.String"/>
    <parameter name="detailDescription5" class="java.lang.String"/>
    <parameter name="detailDescription6" class="java.lang.String"/>
    <parameter name="footerSubreport" class="net.sf.jasperreports.engine.JasperReport"/>
    <parameter name="officeName" class="java.lang.String"/>
    <parameter name="digitalStampPath" class="java.lang.Object"/>

    <detail>
        <band height="510">
            <!-- Header imported first -->
            <subreport>
                <reportElement x="0" y="0" width="802" height="118"/>
                <subreportParameter name="reportLogo"><subreportParameterExpression><![CDATA[$P{reportLogo}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="projectNameAndAddress"><subreportParameterExpression><![CDATA[$P{projectNameAndAddress}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="reportDate"><subreportParameterExpression><![CDATA[$P{reportDate}]]></subreportParameterExpression></subreportParameter>
                <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.JREmptyDataSource(1)]]></dataSourceExpression>
                <subreportExpression class="net.sf.jasperreports.engine.JasperReport"><![CDATA[$P{headerSubreport}]]></subreportExpression>
            </subreport>

            <!-- Section title -->
            <staticText>
                <reportElement x="0" y="118" width="802" height="22" mode="Opaque" backcolor="#005B41" forecolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[صور المشروع وتفاصيل التنفيذ]]></text>
            </staticText>

            <!-- Top grid 2x2 (dynamic loop via datasource) -->
            <subreport>
                <reportElement x="0" y="140" width="802" height="188"/>
                <dataSourceExpression><![CDATA[$P{topGridData}]]></dataSourceExpression>
                <subreportExpression class="net.sf.jasperreports.engine.JasperReport"><![CDATA[$P{topGridSubreport}]]></subreportExpression>
            </subreport>

            <!-- Bottom grid 3x2 (dynamic loop via datasource) -->
            <subreport>
                <reportElement x="0" y="330" width="802" height="170"/>
                <dataSourceExpression><![CDATA[$P{bottomGridData}]]></dataSourceExpression>
                <subreportExpression class="net.sf.jasperreports.engine.JasperReport"><![CDATA[$P{bottomGridSubreport}]]></subreportExpression>
            </subreport>
        </band>
    </detail>

    <summary>
        <band height="85">
            <subreport>
                <reportElement x="0" y="0" width="802" height="85"/>
                <subreportParameter name="officeName"><subreportParameterExpression><![CDATA[$P{officeName}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="digitalStampPath"><subreportParameterExpression><![CDATA[$P{digitalStampPath}]]></subreportParameterExpression></subreportParameter>
                <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.JREmptyDataSource(1)]]></dataSourceExpression>
                <subreportExpression class="net.sf.jasperreports.engine.JasperReport"><![CDATA[$P{footerSubreport}]]></subreportExpression>
            </subreport>
        </band>
    </summary>

</jasperReport>


