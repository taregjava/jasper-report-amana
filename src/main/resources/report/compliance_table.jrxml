    <parameter name="notMatch" class="java.lang.String"/>
    <parameter name="category" class="java.lang.String"/>
    <parameter name="repeat" class="java.lang.String"/>

    <!-- ======================            DETAIL SECTION     ======================= -->
    <detail>
        <band height="50">

            <!-- العمود: م -->
            <textField>
                <reportElement x="0" y="0" width="40" height="50" uuid="a1"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
