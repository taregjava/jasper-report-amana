                <textFieldExpression><![CDATA[$P{item}]]></textFieldExpression>
            </textField>

            <!-- العمود: مطابق -->
            <textField>
                <reportElement x="340" y="0" width="80" height="50" uuid="a3"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$P{match}]]></textFieldExpression>
            </textField>

            <!-- العمود: غير مطابق -->
            <textField>
                <reportElement x="420" y="0" width="80" height="50" uuid="a4"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
