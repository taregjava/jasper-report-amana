				<textElement textAlignment="Center" verticalAlignment="Middle"/>
				<text><![CDATA[إقرار تحمل المسؤولية / التعهد]]></text>
			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="0" y="131" width="802" height="44" backcolor="#F2F9F2" uuid="bd48faf3-2193-44ff-98d9-fad2bd5c2fae"/>
