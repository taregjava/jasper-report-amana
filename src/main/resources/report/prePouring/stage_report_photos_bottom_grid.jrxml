<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="project_start_report_photos_bottom_grid"
              pageWidth="802"
              pageHeight="220"
              columnCount="3"
              printOrder="Horizontal"
              columnWidth="267"
              leftMargin="0"
              rightMargin="0"
              topMargin="0"
              bottomMargin="0"
              whenNoDataType="AllSectionsNoDetail"
              language="java">

    <property name="net.sf.jasperreports.text.direction" value="RTL"/>
    <style name="Default" isDefault="true" fontName="SansSerif" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>

    <field name="number" class="java.lang.String"/>
    <field name="image" class="java.lang.Object"/>
    <field name="description" class="java.lang.String"/>

    <detail>
        <band height="90">
            <staticText>
                <reportElement x="0" y="0" width="267" height="18" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="0" width="267" height="18"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{number}]]></textFieldExpression>
            </textField>

            <frame>
                <reportElement x="0" y="18" width="267" height="46" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <image scaleImage="RetainShape" hAlign="Center" vAlign="Middle">
                    <reportElement x="3" y="3" width="261" height="40">
                        <printWhenExpression><![CDATA[$F{image} != null]]></printWhenExpression>
                    </reportElement>
                    <imageExpression class="java.lang.Object"><![CDATA[$F{image}]]></imageExpression>
                </image>
                <staticText>
                    <reportElement x="3" y="3" width="261" height="40" forecolor="#999999">
                        <printWhenExpression><![CDATA[$F{image} == null]]></printWhenExpression>
                    </reportElement>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                    <text><![CDATA[لا توجد صورة]]></text>
                </staticText>
            </frame>

            <frame>
                <reportElement x="0" y="64" width="267" height="26" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <staticText>
                    <reportElement x="3" y="2" width="56" height="10"/>
                    <textElement textAlignment="Right"><font size="8"/></textElement>
                    <text><![CDATA[وصف الصورة]]></text>
                </staticText>
                <staticText>
                    <reportElement x="64" y="2" width="197" height="10"/>
                    <textElement><font size="8"/></textElement>
                    <text><![CDATA[.................................]]></text>
                </staticText>
                <staticText>
                    <reportElement x="64" y="14" width="197" height="10"/>
                    <textElement><font size="8"/></textElement>
                    <text><![CDATA[.................................]]></text>
                </staticText>
                <textField isBlankWhenNull="true">
                    <reportElement x="64" y="2" width="197" height="22"/>
                    <textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement>
                    <textFieldExpression><![CDATA[$F{description}]]></textFieldExpression>
                </textField>
            </frame>
        </band>
    </detail>

</jasperReport>


