                    <subreportParameter name="stageReportTitle"><subreportParameterExpression><![CDATA[$P{stageReportTitle}]]></subreportParameterExpression></subreportParameter>
                    <subreportParameter name="footerSubreport"><subreportParameterExpression><![CDATA[$P{footerSubreport}]]></subreportParameterExpression></subreportParameter>
                    <subreportParameter name="officeName"><subreportParameterExpression><![CDATA[$P{officeName}]]></subreportParameterExpression></subreportParameter>
                    <subreportParameter name="digitalStampPath"><subreportParameterExpression><![CDATA[$P{digitalStampPath}]]></subreportParameterExpression></subreportParameter>
                    <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.JREmptyDataSource(1)]]></dataSourceExpression>
                    <subreportExpression class="net.sf.jasperreports.engine.JasperReport"><![CDATA[$P{changesPageSubreport}]]></subreportExpression>
                </subreport>
            </band>
        </groupFooter>
    </group>

