    <!--
        Group rendering order (innermost footer first, outermost last):
          1. TableSectionGroup   → checklist table
          2. MainImagesGroup     → main building images
          3. SitePhotosGroup     → site photos page
          4. PhotosGridGroup     → photos top/bottom grid page
          5. ChangesGroup        → changes & extra items
        Final page is rendered by <summary> (inspection responsibility section).
        Declared order in XML: outermost first.
    -->

    <!-- Outermost group: footer renders LAST among groups (changes page) -->
    <group name="ChangesGroup">
        <groupExpression><![CDATA[1]]></groupExpression>
        <groupFooter>
            <band height="545" splitType="Stretch">
                <subreport>
                    <reportElement x="0" y="0" width="802" height="545"/>
                    <subreportParameter name="headerSubreport"><subreportParameterExpression><![CDATA[$P{headerSubreport}]]></subreportParameterExpression></subreportParameter>
                    <subreportParameter name="changesRowsSubreport"><subreportParameterExpression><![CDATA[$P{changesRowsSubreport}]]></subreportParameterExpression></subreportParameter>
