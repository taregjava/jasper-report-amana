<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="project_start_report_table"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="0"
              bottomMargin="0"
              language="java">

    <property name="net.sf.jasperreports.text.direction" value="RTL"/>
    <style name="Default" isDefault="true" fontName="SansSerif" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
    <style name="ChecklistHeader" mode="Opaque" backcolor="#005B41" forecolor="#FFFFFF" fontSize="9" isBold="true" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true">
        <box leftPadding="2" rightPadding="2" topPadding="2" bottomPadding="2">
            <pen lineWidth="0.5" lineColor="#000000"/>
        </box>
    </style>
    <style name="ChecklistCell" mode="Opaque" backcolor="#FFFFFF" forecolor="#000000" fontSize="9" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true">
        <box leftPadding="3" rightPadding="5" topPadding="4" bottomPadding="4">
            <pen lineWidth="0.5" lineColor="#000000"/>
        </box>
    </style>
    <style name="ChecklistCenterCell" style="ChecklistCell">
        <box leftPadding="2" rightPadding="2" topPadding="2" bottomPadding="2">
            <pen lineWidth="0.5" lineColor="#000000"/>
        </box>
    </style>
    <style name="ChecklistGroupCell" mode="Opaque" backcolor="#EBF1DE" forecolor="#000000" fontSize="9" isBold="true" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true">
        <box leftPadding="3" rightPadding="5" topPadding="3" bottomPadding="3">
            <pen lineWidth="0.5" lineColor="#000000"/>
        </box>
    </style>

    <parameter name="headerSubreport" class="net.sf.jasperreports.engine.JasperReport"/>
    <parameter name="reportLogo" class="java.lang.Object"/>
    <parameter name="projectNameAndAddress" class="java.lang.String"/>
    <parameter name="reportDate" class="java.lang.String"/>
    <parameter name="stageReportNumber" class="java.lang.String"/>
    <parameter name="stageReportTitle" class="java.lang.String"/>

    <!-- Fields expected in the table datasource -->
    <field name="groupTitle" class="java.lang.String"/>
    <field name="sideNumber" class="java.lang.String"/>
    <field name="itemNo" class="java.lang.Integer"/>
    <field name="description" class="java.lang.String"/>
    <field name="requirement" class="java.lang.String"/>
    <field name="status" class="java.lang.String"/>
    <field name="statusCode" class="java.lang.String"/>
    <field name="isMatched" class="java.lang.Boolean"/>
    <field name="isNotMatched" class="java.lang.Boolean"/>
    <field name="isNotApplicable" class="java.lang.Boolean"/>
    <field name="match" class="java.lang.String"/>
    <field name="notMatch" class="java.lang.String"/>
    <field name="notApplicable" class="java.lang.String"/>
    <field name="notes" class="java.lang.String"/>

    <variable name="ChecklistGroupRowNo" class="java.lang.Integer" resetType="Group" resetGroup="ChecklistGroup" calculation="Count">
        <variableExpression><![CDATA[1]]></variableExpression>
    </variable>

    <group name="ChecklistGroup" isStartNewPage="false">
        <groupExpression><![CDATA[
            $F{groupTitle} != null && !$F{groupTitle}.trim().isEmpty()
            ? $F{groupTitle}
            : ($F{sideNumber} != null && !$F{sideNumber}.trim().isEmpty()
                ? $F{sideNumber}
                : ($F{itemNo} == null ? "" : String.valueOf($F{itemNo})))
        ]]></groupExpression>
        <groupHeader>
            <band height="22">
                <printWhenExpression><![CDATA[$F{groupTitle} != null && !$F{groupTitle}.trim().isEmpty()]]></printWhenExpression>

                <textField isBlankWhenNull="true">
                    <reportElement style="ChecklistGroupCell" x="0" y="0" width="802" height="22"/>
                    <textElement textAlignment="Right" verticalAlignment="Middle"/>
                    <textFieldExpression><![CDATA[$F{groupTitle}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
    </group>

    <title>
        <band height="118">
            <subreport>
                <reportElement x="0" y="0" width="802" height="118"/>
                <subreportParameter name="reportLogo"><subreportParameterExpression><![CDATA[$P{reportLogo}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="projectNameAndAddress"><subreportParameterExpression><![CDATA[$P{projectNameAndAddress}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="reportDate"><subreportParameterExpression><![CDATA[$P{reportDate}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="stageReportNumber"><subreportParameterExpression><![CDATA[$P{stageReportNumber}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="stageReportTitle"><subreportParameterExpression><![CDATA[$P{stageReportTitle}]]></subreportParameterExpression></subreportParameter>
                <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.JREmptyDataSource(1)]]></dataSourceExpression>
                <subreportExpression class="net.sf.jasperreports.engine.JasperReport"><![CDATA[$P{headerSubreport}]]></subreportExpression>
            </subreport>
        </band>
    </title>

    <columnHeader>
        <band height="32">
            <staticText>
                <reportElement style="ChecklistHeader" x="0" y="0" width="160" height="32"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[ملاحظات]]></text>
            </staticText>

            <staticText>
                <reportElement style="ChecklistHeader" x="160" y="0" width="60" height="32"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[لا ينطبق]]></text>
            </staticText>

            <staticText>
                <reportElement style="ChecklistHeader" x="220" y="0" width="60" height="32"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[غير مطابق]]></text>
            </staticText>

            <staticText>
                <reportElement style="ChecklistHeader" x="280" y="0" width="60" height="32"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[مطابق]]></text>
            </staticText>

            <staticText>
                <reportElement style="ChecklistHeader" x="340" y="0" width="432" height="32"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[المهمة]]></text>
            </staticText>

            <staticText>
                <reportElement style="ChecklistHeader" x="772" y="0" width="30" height="32"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[م]]></text>
            </staticText>
        </band>
    </columnHeader>


    <detail>
        <band height="30" splitType="Stretch">
            <frame>
                <reportElement x="0" y="0" width="802" height="30" positionType="Float"/>

                <textField isBlankWhenNull="true" isStretchWithOverflow="true">
                    <reportElement style="ChecklistCell" x="0" y="0" width="160" height="30" stretchType="RelativeToTallestObject"/>
                    <textElement textAlignment="Right" verticalAlignment="Middle"/>
                    <textFieldExpression><![CDATA[$F{notes}]]></textFieldExpression>
                </textField>

                <textField isBlankWhenNull="true">
                    <reportElement style="ChecklistCenterCell" x="160" y="0" width="60" height="30" stretchType="RelativeToTallestObject"/>
                    <textElement textAlignment="Center" verticalAlignment="Middle">
                        <font size="11" isBold="true" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA[
                        Boolean.TRUE.equals($F{isNotApplicable})
                        || ($F{statusCode} != null && "NOT_APPLICABLE".equals($F{statusCode}))
                        || ($F{status} != null && (
                            "NA".equalsIgnoreCase($F{status}.trim()) ||
                            "N/A".equalsIgnoreCase($F{status}.trim()) ||
                            "لا ينطبق".equals($F{status}.trim())
                        ))
                        ? "X" : ""
                    ]]></textFieldExpression>
                </textField>

                <textField isBlankWhenNull="true">
                    <reportElement style="ChecklistCenterCell" x="220" y="0" width="60" height="30" stretchType="RelativeToTallestObject"/>
                    <textElement textAlignment="Center" verticalAlignment="Middle">
                        <font size="11" isBold="true" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA[
                        Boolean.TRUE.equals($F{isNotMatched})
                        || ($F{statusCode} != null && "NOT_MATCHED".equals($F{statusCode}))
                        || ($F{status} != null && (
                            "☐".equals($F{status}.trim()) ||
                            "✖".equals($F{status}.trim()) ||
                            "✗".equals($F{status}.trim()) ||
                            "X".equalsIgnoreCase($F{status}.trim()) ||
                            "غير مطابق".equals($F{status}.trim())
                        ))
                        ? "X" : ""
                    ]]></textFieldExpression>
                </textField>

                <textField isBlankWhenNull="true">
                    <reportElement style="ChecklistCenterCell" x="280" y="0" width="60" height="30" stretchType="RelativeToTallestObject"/>
                    <textElement textAlignment="Center" verticalAlignment="Middle">
                        <font size="11" isBold="true" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA[
                        Boolean.TRUE.equals($F{isMatched})
                        || ($F{statusCode} != null && "MATCHED".equals($F{statusCode}))
                        || ($F{status} != null && (
                            "☑".equals($F{status}.trim()) ||
                            "✔".equals($F{status}.trim()) ||
                            "✓".equals($F{status}.trim()) ||
                            "مطابق".equals($F{status}.trim())
                        ))
                        ? "X" : ""
                    ]]></textFieldExpression>
                </textField>

                <textField isBlankWhenNull="true" isStretchWithOverflow="true">
                    <reportElement style="ChecklistCell" x="340" y="0" width="432" height="30" stretchType="RelativeToTallestObject"/>
                    <textElement textAlignment="Right" verticalAlignment="Middle"/>
                    <textFieldExpression><![CDATA[$F{description}]]></textFieldExpression>
                </textField>

                <textField isBlankWhenNull="true">
                    <reportElement style="ChecklistCenterCell" x="772" y="0" width="30" height="30" stretchType="RelativeToTallestObject"/>
                    <textElement textAlignment="Center" verticalAlignment="Middle"/>
                    <textFieldExpression><![CDATA[$V{ChecklistGroupRowNo} == null ? "" : String.valueOf($V{ChecklistGroupRowNo})]]></textFieldExpression>
                </textField>
            </frame>
        </band>
    </detail>

</jasperReport>



