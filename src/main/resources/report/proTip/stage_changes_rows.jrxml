<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="oc_verification_changes_rows"
              pageWidth="842"
              pageHeight="160"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="0"
              bottomMargin="0"
              language="java">

    <field name="rowText" class="java.lang.String"/>

    <detail>
        <band height="20" splitType="Stretch">

            <!-- White description cell -->
            <rectangle>
                <reportElement x="0" y="0" width="762" height="20" mode="Opaque" backcolor="#FFFFFF"/>
                <graphicElement>
                    <pen lineWidth="0.5" lineColor="#000000"/>
                </graphicElement>
            </rectangle>

            <!-- Far-right numbering cell -->
            <rectangle>
                <reportElement x="762" y="0" width="40" height="20" mode="Opaque" backcolor="#EBF1DE"/>
                <graphicElement>
                    <pen lineWidth="0.5" lineColor="#000000"/>
                </graphicElement>
            </rectangle>

            <textField isBlankWhenNull="true" textAdjust="CutText">
                <reportElement x="8" y="0" width="739" height="20"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H"
                          isPdfEmbedded="true" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{rowText}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="762" y="0" width="40" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H"
                          isPdfEmbedded="true" size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[String.valueOf($V{REPORT_COUNT})]]></textFieldExpression>
            </textField>

        </band>
    </detail>

</jasperReport>

