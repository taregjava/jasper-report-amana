<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="oc_verification_exterior_photos_page"
              pageWidth="842"
              pageHeight="555"
              orientation="Landscape"
              columnWidth="267"
              columnCount="3"
              columnSpacing="0"
              printOrder="Horizontal"
              leftMargin="20"
              rightMargin="20"
              topMargin="0"
              bottomMargin="0"
              whenNoDataType="AllSectionsNoDetail"
              language="java">

    <property name="net.sf.jasperreports.text.direction" value="RTL"/>
    <style name="Default" isDefault="true" fontName="SansSerif" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>

    <parameter name="headerSubreport" class="net.sf.jasperreports.engine.JasperReport"/>
    <parameter name="reportLogo" class="java.lang.Object"/>
    <parameter name="projectNameAndAddress" class="java.lang.String"/>
    <parameter name="reportDate" class="java.lang.String"/>
    <parameter name="officeName" class="java.lang.String"/>
    <parameter name="stageReportNumber" class="java.lang.String"/>
    <parameter name="stageReportTitle" class="java.lang.String"/>
    <field name="number" class="java.lang.String"/>
    <field name="image" class="java.lang.Object"/>
    <field name="description" class="java.lang.String"/>

    <pageHeader>
        <band height="140">
            <subreport>
                <reportElement x="0" y="0" width="802" height="118"/>
                <subreportParameter name="reportLogo"><subreportParameterExpression><![CDATA[$P{reportLogo}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="projectNameAndAddress"><subreportParameterExpression><![CDATA[$P{projectNameAndAddress}]]></subreportParameterExpression></subreportParameter>
                <subreportParameter name="reportDate"><subreportParameterExpression><![CDATA[$P{reportDate}]]></subreportParameterExpression></subreportParameter>
                <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.JREmptyDataSource(1)]]></dataSourceExpression>
                <subreportExpression class="net.sf.jasperreports.engine.JasperReport"><![CDATA[$P{headerSubreport}]]></subreportExpression>
            </subreport>

            <staticText>
                <reportElement x="0" y="118" width="802" height="22" mode="Opaque" backcolor="#005B41" forecolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[صور للمبني من الخارج]]></text>
            </staticText>
        </band>
    </pageHeader>

    <detail>
        <band height="185">
            <staticText>
                <reportElement x="0" y="0" width="267" height="16" mode="Opaque" backcolor="#EBF1DE"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="0" width="267" height="16"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{number}]]></textFieldExpression>
            </textField>

            <frame>
                <reportElement x="0" y="16" width="267" height="133" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <image scaleImage="RetainShape" hAlign="Center" vAlign="Middle">
                    <reportElement x="2" y="2" width="263" height="129">
                        <printWhenExpression><![CDATA[$F{image} != null]]></printWhenExpression>
                    </reportElement>
                    <imageExpression class="java.lang.Object"><![CDATA[$F{image}]]></imageExpression>
                </image>
                <staticText>
                    <reportElement x="2" y="2" width="263" height="129" forecolor="#999999">
                        <printWhenExpression><![CDATA[$F{image} == null]]></printWhenExpression>
                    </reportElement>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                    <text><![CDATA[لا توجد صورة]]></text>
                </staticText>
            </frame>

            <frame>
                <reportElement x="0" y="149" width="267" height="36" mode="Opaque" backcolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <staticText>
                    <reportElement x="3" y="2" width="58" height="12"/>
                    <textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement>
                    <text><![CDATA[وصف الصورة]]></text>
                </staticText>
                <staticText>
                    <reportElement x="65" y="2" width="199" height="12"/>
                    <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                    <text><![CDATA[.........................................]]></text>
                </staticText>
                <staticText>
                    <reportElement x="65" y="18" width="199" height="12"/>
                    <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                    <text><![CDATA[.........................................]]></text>
                </staticText>
                <textField isBlankWhenNull="true">
                    <reportElement x="65" y="2" width="199" height="28"/>
                    <textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement>
                    <textFieldExpression><![CDATA[$F{description}]]></textFieldExpression>
                </textField>
            </frame>
        </band>
    </detail>

    <pageFooter>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="401" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font size="10"/></textElement>
                <text><![CDATA[ختم المكتب]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="401" y="0" width="401" height="20"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="10"/></textElement>
                <textFieldExpression><![CDATA["اسم المكتب   " + ($P{officeName} == null ? "" : $P{officeName})]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>

