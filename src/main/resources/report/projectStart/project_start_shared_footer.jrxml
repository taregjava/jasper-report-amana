<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="project_start_shared_footer"
              pageWidth="802"
              pageHeight="85"
              columnWidth="802"
              leftMargin="0"
              rightMargin="0"
              topMargin="0"
              bottomMargin="0"
              whenNoDataType="AllSectionsNoDetail">

    <property name="net.sf.jasperreports.text.direction" value="RTL"/>
    <style name="Default" isDefault="true" fontName="SansSerif" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>

    <parameter name="officeName" class="java.lang.String"/>
    <parameter name="digitalStampPath" class="java.lang.Object"/>

    <detail>
        <band height="85">

            <!-- ========== RIGHT SIDE: اسم المكتب ========== -->
            <!-- Bold label -->
            <staticText>
                <reportElement x="648" y="4" width="110" height="18" mode="Opaque" backcolor="#FFFFFF"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10" isBold="true" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <text><![CDATA[اسم المكتب :]]></text>
            </staticText>
            <!-- Dynamic value — immediately to the left of the label -->
            <textField isBlankWhenNull="true">
                <reportElement x="380" y="4" width="266" height="18" mode="Opaque" backcolor="#FFFFFF"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{officeName} == null ? "" : $P{officeName}]]></textFieldExpression>
            </textField>

            <!-- ========== LEFT SIDE: ختم المكتب ========== -->
            <!-- Label anchored to top-left — well above the stamp -->
            <staticText>
                <reportElement x="5" y="4" width="150" height="16" mode="Opaque" backcolor="#FFFFFF"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="10" isBold="true" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <text><![CDATA[ختم المكتب :]]></text>
            </staticText>
            <!-- Stamp image: y=22 gives 6px gap below the label, height=42 fills the space -->
            <image scaleImage="RetainShape" hAlign="Left" vAlign="Middle">
                <reportElement x="5" y="22" width="150" height="42">
                    <printWhenExpression><![CDATA[$P{digitalStampPath} != null]]></printWhenExpression>
                </reportElement>
                <imageExpression class="java.lang.Object"><![CDATA[$P{digitalStampPath}]]></imageExpression>
            </image>

            <!-- ========== DECORATIVE BELT — y=67, safely below all content ========== -->
            <rectangle>
                <reportElement x="0" y="67" width="802" height="3" mode="Opaque" backcolor="#D9DDE3"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="0"   y="67" width="67" height="2" mode="Opaque" backcolor="#E6E9EE"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="134" y="67" width="67" height="2" mode="Opaque" backcolor="#E6E9EE"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="268" y="67" width="67" height="2" mode="Opaque" backcolor="#E6E9EE"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="402" y="67" width="67" height="2" mode="Opaque" backcolor="#E6E9EE"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="536" y="67" width="67" height="2" mode="Opaque" backcolor="#E6E9EE"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="670" y="67" width="67" height="2" mode="Opaque" backcolor="#E6E9EE"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>

            <!-- ========== 3-LAYER BOTTOM BORDER ========== -->
            <line>
                <reportElement x="0" y="71" width="802" height="1" forecolor="#A6A6A6"/>
                <graphicElement><pen lineWidth="0.75"/></graphicElement>
            </line>
            <rectangle>
                <reportElement x="0" y="72" width="802" height="9" mode="Opaque" backcolor="#D9D9D9"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <line>
                <reportElement x="0" y="81" width="802" height="1" forecolor="#A6A6A6"/>
                <graphicElement><pen lineWidth="0.75"/></graphicElement>
            </line>
        </band>
    </detail>

</jasperReport>

