<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="project_start_shared_footer"
              pageWidth="802"
              pageHeight="31"
              columnWidth="802"
              leftMargin="0"
              rightMargin="0"
              topMargin="0"
              bottomMargin="0"
              whenNoDataType="AllSectionsNoDetail">

    <property name="net.sf.jasperreports.text.direction" value="RTL"/>
    <style name="Default" isDefault="true" fontName="SansSerif" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>

    <parameter name="officeName" class="java.lang.String"/>
    <parameter name="digitalStampPath" class="java.lang.Object"/>

    <detail>
        <band height="31">
            <!-- Top labels / values -->
            <staticText>
                <reportElement x="654" y="0" width="148" height="14" mode="Opaque" backcolor="#FFFFFF"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="11" isBold="true" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <text><![CDATA[اسم المكتب]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="470" y="14" width="332" height="9" mode="Opaque" backcolor="#FFFFFF"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="10" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{officeName} == null ? "" : $P{officeName}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="0" width="148" height="14" mode="Opaque" backcolor="#FFFFFF"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="11" isBold="true" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
                </textElement>
                <text><![CDATA[ختم المكتب]]></text>
            </staticText>
            <image scaleImage="RetainShape" hAlign="Left" vAlign="Middle">
                <reportElement x="0" y="14" width="120" height="9">
                    <printWhenExpression><![CDATA[$P{digitalStampPath} != null]]></printWhenExpression>
                </reportElement>
                <imageExpression class="java.lang.Object"><![CDATA[$P{digitalStampPath}]]></imageExpression>
            </image>

            <!-- Decorative belt (triangle-like alternating blocks) -->
            <rectangle>
                <reportElement x="0" y="20" width="802" height="3" mode="Opaque" backcolor="#D9DDE3"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="0" y="20" width="67" height="2" mode="Opaque" backcolor="#E6E9EE"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="134" y="20" width="67" height="2" mode="Opaque" backcolor="#E6E9EE"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="268" y="20" width="67" height="2" mode="Opaque" backcolor="#E6E9EE"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="402" y="20" width="67" height="2" mode="Opaque" backcolor="#E6E9EE"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="536" y="20" width="67" height="2" mode="Opaque" backcolor="#E6E9EE"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="670" y="20" width="67" height="2" mode="Opaque" backcolor="#E6E9EE"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>

            <!-- 3-layer bottom border -->
            <line>
                <reportElement x="0" y="24" width="802" height="1" forecolor="#A6A6A6"/>
                <graphicElement><pen lineWidth="0.75"/></graphicElement>
            </line>
            <rectangle>
                <reportElement x="0" y="25" width="802" height="5" mode="Opaque" backcolor="#D9D9D9"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <line>
                <reportElement x="0" y="30" width="802" height="1" forecolor="#A6A6A6"/>
                <graphicElement><pen lineWidth="0.75"/></graphicElement>
            </line>
        </band>
    </detail>

</jasperReport>


