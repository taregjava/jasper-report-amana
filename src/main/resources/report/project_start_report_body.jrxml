<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="project_start_report_body"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20"
              language="java">

    <property name="net.sf.jasperreports.text.direction" value="RTL"/>
    <style name="Default" isDefault="true" fontName="SansSerif" pdfFontName="fonts/Amiri-Regular.ttf" pdfEncoding="Identity-H" isPdfEmbedded="true"/>

    <!-- Building / body parameters -->
    <!-- Owner parameters (moved from header) -->
    <parameter name="ownerName" class="java.lang.String"/>
    <parameter name="ownerIdNumber" class="java.lang.String"/>
    <parameter name="ownerMobile" class="java.lang.String"/>
    <parameter name="contractorName" class="java.lang.String"/>
    <parameter name="supervisingEngineeringOffice" class="java.lang.String"/>
    <parameter name="buildingType" class="java.lang.String"/>
    <parameter name="buildingCondition" class="java.lang.String"/>
    <parameter name="buildingDescription" class="java.lang.String"/>
    <parameter name="licenseNumber" class="java.lang.String"/>
    <parameter name="licenseDate" class="java.lang.String"/>
    <parameter name="planNumber" class="java.lang.String"/>
    <parameter name="plotNumber" class="java.lang.String"/>
    <parameter name="floorsCount" class="java.lang.String"/>
    <parameter name="landAreaDeed" class="java.lang.String"/>
    <parameter name="landAreaLicense" class="java.lang.String"/>
    <parameter name="landAreaActual" class="java.lang.String"/>
    <parameter name="district" class="java.lang.String"/>
    <parameter name="street" class="java.lang.String"/>

    <title>
        <band height="260">
            <!-- Ownership header banner moved here -->
            <rectangle>
                <reportElement x="10" y="0" width="782" height="26" mode="Opaque" backcolor="#0B5D4F"/>
            </rectangle>
            <staticText>
                <reportElement x="660" y="0" width="132" height="26"/>
                <textElement textAlignment="Right">
                    <font size="12" isBold="true" pdfFontName="fonts/Amiri-Regular.ttf"/>
                </textElement>
                <text><![CDATA[بيانات الملكية]]></text>
            </staticText>

            <!-- simple owner fields (for body subreport) -->
            <staticText>
                <reportElement x="660" y="36" width="120" height="16"/>
                <textElement textAlignment="Right"/>
                <text><![CDATA[اسم المالك:]]></text>
            </staticText>
            <textField>
                <reportElement x="500" y="36" width="140" height="16"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$P{ownerName}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="350" y="36" width="140" height="16"/>
                <textElement textAlignment="Right"/>
                <text><![CDATA[رقم الهوية:]]></text>
            </staticText>
            <textField>
                <reportElement x="200" y="36" width="140" height="16"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$P{ownerIdNumber}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="660" y="56" width="120" height="16"/>
                <textElement textAlignment="Right"/>
                <text><![CDATA[رقم الجوال:]]></text>
            </staticText>
            <textField>
                <reportElement x="500" y="56" width="140" height="16"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$P{ownerMobile}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="350" y="56" width="140" height="16"/>
                <textElement textAlignment="Right"/>
                <text><![CDATA[المقاول:]]></text>
            </staticText>
            <textField>
                <reportElement x="200" y="56" width="140" height="16"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$P{contractorName}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="660" y="76" width="120" height="16"/>
                <textElement textAlignment="Right"/>
                <text><![CDATA[المكتب الهندسي:]]></text>
            </staticText>
            <textField>
                <reportElement x="500" y="76" width="300" height="16"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$P{supervisingEngineeringOffice}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="10" y="120" width="782" height="26" mode="Opaque" backcolor="#0B5D4F"/>
            </rectangle>
            <staticText>
                <reportElement x="660" y="120" width="132" height="26"/>
                <textElement textAlignment="Right">
                    <font size="12" isBold="true" pdfFontName="fonts/Amiri-Regular.ttf"/>
                </textElement>
                <text><![CDATA[معلومات المبنى]]></text>
            </staticText>

            <!-- example row: type, condition, description -->
            <staticText>
                <reportElement x="660" y="136" width="120" height="16"/>
                <textElement textAlignment="Right"/>
                <text><![CDATA[نوع المبنى:]]></text>
            </staticText>
            <textField>
                <reportElement x="500" y="136" width="140" height="16"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$P{buildingType}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="350" y="136" width="140" height="16"/>
                <textElement textAlignment="Right"/>
                <text><![CDATA[حالة المبنى:]]></text>
            </staticText>
            <textField>
                <reportElement x="200" y="136" width="140" height="16"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$P{buildingCondition}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="660" y="160" width="120" height="16"/>
                <textElement textAlignment="Right"/>
                <text><![CDATA[وصف المبنى:]]></text>
            </staticText>
            <textField isStretchWithOverflow="true">
                <reportElement x="12" y="160" width="758" height="40"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$P{buildingDescription}]]></textFieldExpression>
            </textField>

            <!-- license / plan row -->
            <staticText>
                <reportElement x="660" y="208" width="120" height="16"/>
                <textElement textAlignment="Right"/>
                <text><![CDATA[رقم الرخصة:]]></text>
            </staticText>
            <textField>
                <reportElement x="500" y="208" width="140" height="16"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$P{licenseNumber}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="350" y="208" width="140" height="16"/>
                <textElement textAlignment="Right"/>
                <text><![CDATA[تاريخ الرخصة:]]></text>
            </staticText>
            <textField>
                <reportElement x="200" y="208" width="140" height="16"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$P{licenseDate}]]></textFieldExpression>
            </textField>

        </band>
    </title>

</jasperReport>

